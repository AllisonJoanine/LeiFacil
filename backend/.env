# Configurações do Backend LeiFácil

# API Key da OpenAI
# Obtenha em: https://platform.openai.com/api-keys
OPENAI_API_KEY=chave aqui

# Porta do servidor (opcional, padrão: 3000)
PORT=3000

# IMPORTANTE:
# 1. Copie este arquivo para .env
# 2. Substitua a API key pela sua chave real
# 3. NUNCA commit o arquivo .env no Git
# 4. Adicione .env no .gitignore
